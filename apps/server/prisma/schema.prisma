generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// МОДУЛЬ: Профили и Пары
// ==========================================
model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String
  firstName     String
  lastName      String
  
  // Для интеграции с модулем Performance & Analytics
  wdsfMin         String?    // WDSF MIN (Member ID Number)
  wdsfProfileUrl  String?    // Full WDSF athlete profile URL (contains UUID)
  wdsfData        Json?      // Cached parsed data from WDSF profile page
  wdsfUpdatedAt   DateTime?  // When WDSF data was last fetched
  dtvId           String?    // DTV ID номер

  resetToken       String?
  resetTokenExpiry DateTime?

  // Module 1: target monthly spending budget
  monthlyBudget Float?
  // Preferred display currency (ISO 4217 code, e.g. EUR, USD, GBP)
  currency      String     @default("EUR")

  // Consent: when the user accepted the Privacy Policy. Null = not yet accepted
  // (new accounts), which gates the app behind the acceptance screen.
  privacyAcceptedAt DateTime?
  
  // Связи
  couplesAsLead   Couple[]   @relation("LeadPartner")
  couplesAsFollow Couple[]   @relation("FollowPartner")
  couplesAsCoach  Couple[]   @relation("CoachPartner") // Couples where this user is the coach
  proposalsSent   Proposal[] @relation("ProposalSender")
  expenses        Expense[]
  ownedEvents     Event[]    @relation("EventOwner") // Projects this user owns directly (Module 1)
  scheduleEntries ScheduleEntry[] // Calendar sessions (Module 2)
  budgets         MonthlyBudget[] // Per-month spending limits (Module 1)
  messages        Message[]      @relation("MessageAuthor") // Chat/activity messages authored
  messageReads    MessageRead[]  // Per-couple read state
  pushTokens      PushToken[]    // Expo push notification tokens

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Couple {
  id          String     @id @default(uuid())
  leadId      String
  followId    String
  coachId     String?    // Optional coach — a third member with full access to the couple
  isActive    Boolean    @default(true)

  lead        User       @relation("LeadPartner", fields: [leadId], references: [id])
  follow      User       @relation("FollowPartner", fields: [followId], references: [id])
  coach       User?      @relation("CoachPartner", fields: [coachId], references: [id])

  proposals   Proposal[]
  events      Event[]
  messages    Message[]
  reads       MessageRead[]

  createdAt   DateTime   @default(now())
}

// ==========================================
// МОДУЛЬ: Chat / Activity feed (партнёры + тренер)
// ==========================================
// One feed per couple. Holds chat text, posted proposals, and SYSTEM activity
// entries auto-created on every change so partners + coach see everything.
model Message {
  id         String      @id @default(uuid())
  coupleId   String
  authorId   String?     // null for SYSTEM activity entries
  kind       MessageKind @default(TEXT)
  body       String
  meta       Json?       // structured details (resource, action, amount, etc.)
  proposalId String?     // linked Proposal when kind = PROPOSAL

  couple     Couple      @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  author     User?       @relation("MessageAuthor", fields: [authorId], references: [id])

  createdAt  DateTime    @default(now())

  @@index([coupleId, createdAt])
}

// Per-user read pointer for unread badge counts.
model MessageRead {
  id         String   @id @default(uuid())
  coupleId   String
  userId     String
  lastReadAt DateTime @default(now())

  couple     Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([coupleId, userId])
}

// Expo push notification token registered per device.
model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String?

  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// МОДУЛЬ: Partner Sync (Синхронизация)
// ==========================================
model Proposal {
  id          String         @id @default(uuid())
  coupleId    String
  senderId    String
  
  title       String
  type        ProposalType   
  status      ProposalStatus @default(PENDING)
  cost        Float?         // Предлагаемая стоимость (например, 50€ за индив)
  currency    String         @default("EUR")
  
  // JSON для гибких деталей: дата, геолокация, ссылка на отель, имя тренера
  details     Json?          
  
  couple      Couple         @relation(fields: [coupleId], references: [id])
  sender      User           @relation("ProposalSender", fields: [senderId], references: [id])
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// ==========================================
// МОДУЛЬ: Smart Calendar & Analytics
// ==========================================
model Event {
  id          String      @id @default(uuid())
  // A project is owned either directly by a user (solo, Module 1) or by a couple.
  ownerId     String?
  coupleId    String?
  title       String
  date        DateTime
  endDate     DateTime?
  type        EventType
  location    String?

  // --- Module 1: Finance & Logistics (the "Project" A-to-Z) ---
  budget       Float?       // Planned/expected spend for this project (forecasting)
  hotelName    String?
  hotelAddress String?
  checkIn      DateTime?
  checkOut     DateTime?

  // Аналитика (премиум фичи)
  resultPlace Int?        // Занятое место
  skatingData Json?       // Детализация (skating system), оценки судей

  owner       User?       @relation("EventOwner", fields: [ownerId], references: [id])
  couple      Couple?     @relation(fields: [coupleId], references: [id])
  expenses    Expense[]
  attachments Attachment[]
  checklist   ChecklistItem[]
  scheduleEntries ScheduleEntry[] // Calendar sessions linked to this project (Module 2)

  createdAt   DateTime    @default(now())
}

// PDF tickets, hotel/flight bookings attached to a project
model Attachment {
  id        String   @id @default(uuid())
  eventId   String
  label     String   // Human label, e.g. "Flight ticket", "Hotel booking"
  fileName  String   // Original file name
  fileUrl   String   // Public URL served from /uploads
  mimeType  String
  size      Int      // bytes

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// Prep checklist item for a project
model ChecklistItem {
  id        String   @id @default(uuid())
  eventId   String
  text      String
  isDone    Boolean  @default(false)

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ==========================================
// МОДУЛЬ: Finance & Logistics
// ==========================================
model Expense {
  id          String          @id @default(uuid())
  userId      String          // Кто именно платил (для разделения бюджета)
  eventId     String?         // Привязка траты к турниру или сборам
  
  title       String?
  category    ExpenseCategory
  amount      Float
  currency    String          @default("EUR")
  date        DateTime
  description String?
  status      ExpenseStatus   @default(PAID) // PLANNED expenses drive forecasting

  user        User            @relation(fields: [userId], references: [id])
  event       Event?          @relation(fields: [eventId], references: [id])
  scheduleEntry ScheduleEntry? // Set when this expense was auto-created from a calendar session

  createdAt   DateTime        @default(now())
}

// ==========================================
// МОДУЛЬ 2: Smart Calendar (daily schedule)
// ==========================================
// A lightweight calendar item: a single training/practice/competition/rest day, etc.
// Distinct from Event (which is a multi-part "Project" with checklist/attachments).
model ScheduleEntry {
  id        String      @id @default(uuid())
  userId    String
  eventId   String?     // Optional link to a Project (tournament/camp)
  expenseId String?     @unique // Optional auto-created expense when the session has a cost

  title     String
  type      SessionType
  date      DateTime    // The calendar day, or start day for multi-day events (UTC midnight)
  endDate   DateTime?   // Optional end day for multi-day events (inclusive)
  startTime String?     // "HH:MM" (local), optional
  endTime   String?     // "HH:MM" (local), optional
  allDay    Boolean     @default(false)
  location  String?
  notes     String?

  user      User        @relation(fields: [userId], references: [id])
  event     Event?      @relation(fields: [eventId], references: [id])
  expense   Expense?    @relation(fields: [expenseId], references: [id])

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

// Per-month spending limit. Falls back to User.monthlyBudget when no row exists.
model MonthlyBudget {
  id     String @id @default(uuid())
  userId String
  month  String // "YYYY-MM"
  amount Float

  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, month])
}

// ==========================================
// МОДУЛЬ: WDSF World Ranking cache (Tournament Rating)
// ==========================================
// Cached top-N world-ranking snapshot per (CombinedType, month). Shared across all
// users and competitions; past months are immutable so they cache indefinitely.
model WdsfRankingSnapshot {
  id            String   @id @default(uuid())
  combinedType  String   // e.g. "1_180_56_0_0" (Adult Standard)
  snapshotMonth String   // "YYYY-MM" derived from the tournament date
  data          Json     // RankedCouple[] (top-N)
  fetchedAt     DateTime @default(now())

  @@unique([combinedType, snapshotMonth])
}

// --- Энумераторы (Enums) ---

enum MessageKind {
  SYSTEM   // auto-generated activity entry (a change was made)
  TEXT     // free-text chat message
  PROPOSAL // a proposal posted into the chat
}

enum ProposalType {
  TRAINING
  TOURNAMENT
  HOTEL
  TRANSPORT
  OTHER
}

enum ProposalStatus {
  PENDING
  APPROVED
  DECLINED
}

enum EventType {
  TOURNAMENT
  CAMP
  PRACTICE
  INDIVIDUAL
  GROUP_LESSON
}

enum ExpenseStatus {
  PLANNED
  PAID
}

enum SessionType {
  INDIVIDUAL
  GROUP_LESSON
  PRACTICE
  COMPETITION
  CAMP
  REST
  OTHER
}

enum ExpenseCategory {
  INDIVIDUAL
  GROUP
  PRACTICE
  HALL_RENT
  COSTUME
  FLIGHT
  TRANSPORT
  HOTEL
  FOOD
  START_FEE
  ENTRY_TICKET
  VISA
  OTHER
}